{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://chess-game-brle.onrender.com/api/:path*"
    },
    {
      "source": "/ws",
      "destination": "https://chess-game-brle.onrender.com/ws"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://chess-game-brle.onrender.com/ws/:path*"
    },
    {
      "source": "/((?!api|ws|assets|vite.svg).*)",
      "destination": "/index.html"
    }
  ]
}
